{
  "ignorePaths": [
    "**/package.json",
    "**/package-lock.json",
    "**/node_modules/**",
    "**/vscode-extension/**",
    "**/.git/objects/**",
    ".vscode",
    ".vscode-insiders"
  ],
  "ignoreWords": ["imgtext", "navbtn", "lorem", "ipsum", "dolor", "sit", "amet"],
  "words": [
    "adduser",
    "ardvark",
    "argname",
    "argtype",
    "Cgreen",
    "Creset",
    "Ctype",
    "dbname",
    "dpkg",
    "drwx",
    "drwxr",
    "drwxrwxr",
    "dumpcap",
    "fooey",
    "getcap",
    "hoge",
    "lanname",
    "libc",
    "macfoo",
    "modelcontextprotocol",
    "oneline",
    "pdfseparate",
    "pdftk",
    "pgdg",
    "pgtap",
    "plpgsql",
    "precommit",
    "psql",
    "rettype",
    "ROWTYPE",
    "sabafoo",
    "sdace",
    "USENAME",
    "usermod",
    "Wireshark"
  ]
}
