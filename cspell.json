{
  "ignorePaths": [
    "**/package.json",
    "**/package-lock.json",
    "**/node_modules/**",
    "**/vscode-extension/**",
    "**/.git/objects/**",
    ".vscode",
    ".vscode-insiders"
  ],
  "ignoreWords": [
    "imgtext",
    "navbtn",
    "lorem",
    "ipsum",
    "dolor",
    "sit",
    "amet"
  ],
  "words": [
    "adduser",
    "Cgreen",
    "Creset",
    "modelcontextprotocol",
    "oneline",
    "pdfseparate",
    "pdftk",
    "precommit",
    "psql"
  ]
}
